# Public (shipped to browser via Vite — must NOT contain secrets)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_STRAVA_CLIENT_ID=
VITE_APP_URL=http://localhost:3002

# Used by the admin user-generation page (godaddy/users/generate) — ships to
# browser via `dangerouslyAllowBrowser`. Treat as semi-public; do not reuse for
# anything else and rotate if leaked.
VITE_CLAUDE_KEY=

# Server-only secrets — set via `supabase secrets set --env-file=...`.
# Listing them here just documents what the Edge Functions need configured.
SB_PUBLISHABLE_KEY=
SB_SECRET_KEY=
STRAVA_CLIENT_SECRET=
STRAVA_WEBHOOK_VERIFY_TOKEN=
CLAUDE_KEY=
